# open-db-mcp 环境变量示例
# 复制到 ~/.open-db-mcp/.env 或当前目录 .env 后按需修改

# datasources.json 配置文件路径（默认 config/datasources.json）
MCP_DATASOURCES_CFG_PATH=config/datasources.json

# jdbc.properties 文件绝对路径（若未在 config.yaml 中配置）
MCP_JDBC_PROPERTIES_PATH=/path/to/your/jdbc.properties

# 达梦 JDBC 驱动 jar 绝对路径（默认随包内置 libs/DmJdbcDriver18.jar）
MCP_DM_JDBC_JAR_PATH=libs/DmJdbcDriver18.jar

# 连接池
MCP_POOL_MIN=1
MCP_POOL_MAX=8

# 单次 DML 最大影响行数（软上限）
MCP_MAX_AFFECTED_ROWS=1000

# 审计日志路径
MCP_AUDIT_LOG_PATH=/home/youruser/.open-db-mcp/audit.jsonl
MCP_AUDIT_ENABLED=true
