{
  "LOCAL_MYSQL": {
    "read": {
      "allowed_tables": ["test_db.*"],
      "forbidden_columns": ["password", "salt", "token"],
      "max_rows": 1000
    },
    "write": {
      "allowed_tables": ["test_db.users", "test_db.orders"],
      "allowed_columns": ["name", "email", "status"],
      "max_affected_rows": 100,
      "require_where": true
    },
    "ddl": {
      "allowed": false
    }
  },
  "ORACLE_SAMPLE": {
    "read": {
      "allowed_tables": ["HR.*"],
      "forbidden_columns": ["PASSWORD", "SALARY"],
      "max_rows": 500
    },
    "write": {
      "allowed_tables": ["HR.EMPLOYEES"],
      "allowed_columns": ["FIRST_NAME", "LAST_NAME", "EMAIL"],
      "max_affected_rows": 50,
      "require_where": true
    },
    "ddl": {
      "allowed": false
    }
  }
}
